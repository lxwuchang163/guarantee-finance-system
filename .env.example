# =============================================
# 担保集团业务财务系统 - 环境变量配置模板
# 复制此文件为 .env 并修改实际值
# =============================================

# MySQL配置
MYSQL_ROOT_PASSWORD=Guarantee@2024
MYSQL_PORT=3306

# Redis配置
REDIS_PASSWORD=GuaranteeRedis2024
REDIS_PORT=6379

# 后端服务端口
BACKEND_PORT=8080

# 前端服务端口
FRONTEND_PORT=80

# JWT密钥（生产环境请务必修改为复杂随机字符串）
JWT_SECRET=your-complex-jwt-secret-key-change-in-production

# 用友NC Cloud对接配置
NC_CLOUD_BASE_URL=http://your-nc-cloud-server:8080/nccloud
NC_CLOUD_USERNAME=admin
NC_CLOUD_PASSWORD=admin123
NC_CLOUD_CLIENT_ID=guarantee_finance
NC_CLOUD_DATA_SOURCE=default
NC_CLOUD_GROUP_CODE=JT01

# CFCA证书配置路径
CFCA_CERT_PATH=/app/certs
CFCA_KEYSTORE_PASSWORD=changeit
